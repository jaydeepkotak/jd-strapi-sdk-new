{
  "kind": "singleType",
  "collectionName": "layouts",
  "info": {
    "singularName": "layout",
    "pluralName": "layouts",
    "displayName": "Global Layout",
    "description": "Global settings for Layout Service"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "siteName": {
        "type": "string",
        "default": "JD"
    },
    "defaultSeo": {
        "type": "component",
        "repeatable": false,
        "component": "shared.seo"
    },
    "header": {
      "type": "dynamiczone",
      "components": [
        "core.header"
      ]
    },
    "footer": {
      "type": "dynamiczone",
      "components": [
        "core.footer"
      ]
    }
  }
}
