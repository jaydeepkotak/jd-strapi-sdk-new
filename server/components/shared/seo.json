{
  "collectionName": "components_shared_seos",
  "info": {
    "displayName": "Seo",
    "icon": "search",
    "description": "Defines SEO metadata including meta title, description, and social share image to optimize page visibility and ranking in search engines."
  },
  "options": {},
  "attributes": {
    "metaTitle": {
      "type": "string",
      "required": true,
      "maxLength": 60
    },
    "metaDescription": {
      "type": "string",
      "maxLength": 160
    },
    "metaImage": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images",
        "files",
        "videos"
      ]
    }
  }
}
